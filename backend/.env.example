OPENWRT_HOST=192.168.1.1
OPENWRT_PORT=80
OPENWRT_USER=root
OPENWRT_PASS=your_router_password
OPENWRT_TIMEOUT=10
FASTAPI_DEBUG=0

# Comma-separated origins allowed to call the API. Defaults below cover the
# Vite dev server and the bundled production server on localhost.
CORS_ORIGINS=http://localhost:5173,http://localhost:5000
